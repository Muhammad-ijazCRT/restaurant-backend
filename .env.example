# Server
NODE_ENV=development
PORT=5001
HOST=0.0.0.0
LOG_LEVEL=info

# Security
JWT_SECRET=change-me-to-a-long-random-string-in-production
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW=1 minute

# CORS is open to all origins by default (origin: true in app.ts).
# Uncomment to restrict to specific origins in production if needed:
# CORS_ORIGIN=https://your-app.vercel.app

# Database (MySQL — Railway provides DATABASE_URL)
DATABASE_URL=mysql://root:password@127.0.0.1:3306/restaurant_portal
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=restaurant_portal

# Email (optional)
ENABLE_ACTIVITY_EMAILS=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=Russian Restaurant Portal
