# Server
NODE_ENV=production
PORT=5000
HOST=0.0.0.0
LOG_LEVEL=info

# Security
JWT_SECRET=change-me-to-a-long-random-string-in-production
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW=1 minute

# Frontend URL (used in emails + CORS)
CORS_ORIGIN=https://restaurant-frontend-ten-livid.vercel.app
FRONTEND_URL=https://restaurant-frontend-ten-livid.vercel.app

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host.neon.tech/neondb?sslmode=require

# Email (optional)
ENABLE_ACTIVITY_EMAILS=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=Russian Restaurant Portal
