{
  "name": "restaurant-portal-api",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "prisma generate && esbuild src/server.ts --bundle --platform=node --format=esm --outdir=dist --packages=external --sourcemap",
    "start": "node --env-file=.env dist/server.js",
    "check": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx --env-file=.env scripts/seed.ts",
    "db:reset": "prisma db push --force-reset --accept-data-loss && tsx --env-file=.env scripts/seed.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/jwt": "^9.0.4",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/static": "^8.1.1",
    "@prisma/client": "^6.3.1",
    "drizzle-orm": "^0.39.3",
    "drizzle-zod": "^0.7.0",
    "fastify": "^5.2.1",
    "postgres": "^3.4.5",
    "nodemailer": "^8.0.10",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.2",
    "zod-validation-error": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.27",
    "@types/nodemailer": "^8.0.0",
    "esbuild": "^0.25.12",
    "prisma": "^6.3.1",
    "tsx": "^4.20.5",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
